# Salin file ini jadi .env untuk development lokal (vercel dev), atau
# tambahkan tiap variabel ini di Vercel Dashboard -> Project -> Settings ->
# Environment Variables untuk production. JANGAN commit file .env berisi
# nilai asli ke git.

# --- Sudah ada sebelumnya (sistem login admin) ---
DATABASE_URL=postgres://user:password@host:5432/dbname
JWT_SECRET=ganti-dengan-string-acak-yang-panjang

# Akun admin (Potter, Darto, Jarot, dst) TIDAK lagi disimpan lewat env var.
# Dibuat/diupdate lewat tabel `users` di database, pakai:
#   node scripts/seed-admin.js
# (jalankan lokal dengan DATABASE_URL di atas sudah di-set).

# --- Baru: notifikasi email untuk sistem akses data vital (riwayat-air-baku) ---
# Alamat Gmail pengirim notifikasi (juga dipakai sebagai login SMTP).
GMAIL_USER=potter.sab@gmail.com
# App Password Gmail (BUKAN password akun biasa). Buat di:
# https://myaccount.google.com/apppasswords (perlu 2-Step Verification aktif).
GMAIL_APP_PASSWORD=ganti-dengan-app-password-16-karakter
# Alamat tujuan notifikasi permintaan akses (biasanya sama dengan GMAIL_USER).
ADMIN_EMAIL=potter.sab@gmail.com

# Opsional: base URL public deployment, dipakai untuk membangun link approve
# di email (misal https://pottersab.vercel.app). Kalau tidak diisi, otomatis
# dideteksi dari header request (host + x-forwarded-proto) — biasanya sudah
# cukup di Vercel, jadi variabel ini boleh dikosongkan.
APP_BASE_URL=
